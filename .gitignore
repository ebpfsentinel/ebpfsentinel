# Rust
/target/
**/target/
**/*.rs.bk
# Cargo.lock is committed for the root workspace (binary crate).
# eBPF program sub-locks are tracked separately.
# Cargo.lock

# eBPF build artifacts
crates/ebpf-programs/*/target/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local

# Fuzzing (generated by cargo-fuzz)
fuzz/corpus/
fuzz/artifacts/

# Secrets
*.pem
*.key
credentials.json

# Allow test fixture keys (not real secrets, used by include_bytes! in tests)
!crates/adapters/tests/fixtures/*.pem

# IA
CLAUDE.*
.claude

# Mutation testing
mutants.out/

# Coverage
*.profraw
*.profdata

# Docker image export
ebpfsentinel-image.tar

# Infra
.vagrant

# Built eBPF programs collected for the Docker image (regenerated by `cargo xtask ebpf-build` / CI)
ebpf-out/

# Talos e2e cluster machine configs (generated by `talosctl cluster create`)
/controlplane.yaml
/worker.yaml
/talosconfig
