# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Vagrantfile for eBPFsentinel integration testing.
#
# Two topologies are supported from this single file:
#
#   2-VM mode (default):
#     - agent:    runs the eBPF agent (builds, provisions, serves endpoints)
#     - attacker: runs attack/test tools against the agent VM
#     Single private network: 192.168.56.0/24 (agent .10, attacker .20).
#
#   3-VM mode (transit topology, set VAGRANT_3VM=1):
#     - attacker: client side (192.168.56.20, default route -> agent)
#     - agent:    dual-homed router (eth1 192.168.56.10, eth2 192.168.57.10,
#                 ip_forward=1, eBPF programs attached on transit traffic)
#     - backend:  service side (192.168.57.30, iperf3/nginx/sshd/openssl
#                 s_server, default route -> agent)
#     Used for DSR load balancing, transit NAT/QoS, multi-WAN failover,
#     and TLS-MITM scenarios.
#
# Usage:
#   vagrant up                # Create and provision the default topology
#   VAGRANT_3VM=1 vagrant up  # Create and provision the 3-VM transit topology
#   vagrant up agent          # Create agent VM only
#   vagrant up attacker       # Create attacker VM only
#   VAGRANT_3VM=1 vagrant up backend
#   vagrant ssh {agent,attacker,backend}
#   vagrant halt              # Stop VMs
#   vagrant destroy -f        # Delete VMs
#
# Environment variables:
#   AGENT_VM_CPUS     Agent VM vCPUs (default: 4)
#   AGENT_VM_MEMORY   Agent VM RAM in MB (default: 4096)
#   VAGRANT_3VM       Set to "1" / "true" to enable the 3-VM transit topology
#
# Provider: VirtualBox (default) or VMware Workstation (vmware_desktop)
# Base box: bento/ubuntu-24.04 (provisioned inline)
#
# Network: VMs communicate over a VirtualBox host-only network (192.168.56.0/24)
# with MTU 1500 (vmxnet3 native XDP caps MTU at ~3000), TCP BBR, tuned buffers. In 3-VM
# mode a second host-only network 192.168.57.0/24 is added between agent
# and backend.

VAGRANTFILE_API_VERSION = "2"

# 3-VM mode toggle (transit topology with a dedicated backend VM).
VAGRANT_3VM = %w[1 true yes on].include?((ENV["VAGRANT_3VM"] || "").downcase)

# Internal network name shared by both VMs (faster than host-only)

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|

  # ============================================================
  # Agent VM — primary, runs the eBPF security agent
  # ============================================================
  config.vm.define "agent", primary: true do |agent|
    agent.vm.box = "bento/ubuntu-24.04"
    agent.vm.hostname = "ebpf-agent"
    agent.vm.boot_timeout = 600

    # Private network for inter-VM communication
    agent.vm.network "private_network", ip: "192.168.56.10"

    # In 3-VM transit mode, attach a second NIC on the backend network.
    if VAGRANT_3VM
      agent.vm.network "private_network", ip: "192.168.57.10"
    end

    # Port forwards for direct host access to agent endpoints
    agent.vm.network "forwarded_port", guest: 8080, host: 8080, auto_correct: true
    agent.vm.network "forwarded_port", guest: 50051, host: 50051, auto_correct: true
    agent.vm.network "forwarded_port", guest: 9090, host: 9090, auto_correct: true
    agent.vm.network "forwarded_port", guest: 8443, host: 8443, auto_correct: true

    # Sync project directory into VM
    agent.vm.synced_folder "../../../", "/home/vagrant/ebpfsentinel",
      type: "rsync",
      rsync__exclude: [".git/", "target/", "node_modules/", ".vagrant/"]

    # VirtualBox provider (default)
    agent.vm.provider "virtualbox" do |vb|
      vb.memory = ENV.fetch('AGENT_VM_MEMORY', '4096').to_i
      vb.cpus = ENV.fetch('AGENT_VM_CPUS', '4').to_i
      vb.name = "eBPFsentinel Agent VM"
      vb.gui = false
      # Nested virtualization for Docker / eBPF
      vb.customize ["modifyvm", :id, "--nested-hw-virt", "on"]
    end

    # VMware Workstation provider (alternative)
    agent.vm.provider "vmware_desktop" do |v|
      v.vmx["memsize"] = ENV.fetch('AGENT_VM_MEMORY', '4096')
      v.vmx["numvcpus"] = ENV.fetch('AGENT_VM_CPUS', '4')
      v.vmx["displayname"] = "eBPFsentinel Agent VM"
      v.gui = false
      v.linked_clone = false
      # vmxnet3 supports native XDP (XDP_TX included); the default e1000e
      # has no native XDP, which the kfunc XDP datapath requires.
      # Per-driver XDP support + max MTU matrix:
      #   https://docs.ebpf.io/linux/program-type/BPF_PROG_TYPE_XDP/#max-mtu
      v.vmx["ethernet0.virtualDev"] = "vmxnet3"
      v.vmx["ethernet1.virtualDev"] = "vmxnet3"
      v.vmx["ethernet2.virtualDev"] = "vmxnet3"
    end

    # ----------------------------------------------------------
    # Provisioner: base-packages
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "base-packages", inline: <<-SHELL
      set -euxo pipefail
      export DEBIAN_FRONTEND=noninteractive

      apt-get update
      apt-get install -y --no-install-recommends \
        build-essential pkg-config libssl-dev libpcap-dev protobuf-compiler llvm-dev \
        linux-headers-$(uname -r) iproute2 tcpdump curl wget jq git \
        ca-certificates openssl \
        iperf3 hping3 ncat stress-ng bc \
        conntrack

      # Install bpftool if available
      apt-get install -y --no-install-recommends linux-tools-$(uname -r) bpftool 2>/dev/null || true

      # Start iperf3 server for bandwidth testing
      systemctl enable --now iperf3 2>/dev/null || iperf3 -s -D

      # eBPF sysctl tuning
      cat >> /etc/sysctl.d/99-ebpfsentinel.conf <<SYSCTL
net.core.bpf_jit_enable=1
kernel.perf_event_paranoid=-1
SYSCTL
      sysctl --system

      # Raise memlock limit for eBPF map allocation
      cat >> /etc/security/limits.d/99-ebpfsentinel.conf <<LIMITS
*  soft  memlock  unlimited
*  hard  memlock  unlimited
LIMITS
    SHELL

    # ----------------------------------------------------------
    # Provisioner: kernel-hwe
    #
    # The agent enforces a hard minimum kernel of 6.9 (BPF token
    # delegation, BPF_MAP_TYPE_ARENA, kfuncs, dynptr) with no fallback.
    # The bento/ubuntu-24.04 box ships 6.8, so without this the agent
    # refuses to start and every eBPF suite's setup_file fails. Install
    # the HWE kernel (>= 6.9) and reboot into it. The Ubuntu HWE kernel
    # ships vboxsf/vboxguest in-tree, so the synced folder still mounts
    # after the reboot without rebuilding the ISO guest additions.
    #
    # bpftool ships in linux-tools-<kernelver>; base-packages installed
    # the 6.8 tools, which the /usr/bin/bpftool wrapper can no longer
    # dispatch to once we're on the HWE kernel. Pull the HWE tools meta
    # so bpftool tracks whatever kernel the HWE line provides.
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "kernel-hwe", reboot: true, inline: <<-SHELL
      set -euxo pipefail
      export DEBIAN_FRONTEND=noninteractive

      apt-get update

      # Ensure bpftool tracks the HWE kernel (idempotent; runs whether or
      # not the kernel itself needs upgrading, so a re-provision of an
      # already-upgraded box still repairs a stale tools package).
      apt-get install -y --no-install-recommends linux-tools-generic-hwe-24.04

      running="$(uname -r | sed 's/-generic//')"
      if dpkg --compare-versions "$running" ge 6.9; then
        echo "kernel $running already >= 6.9, nothing to do"
        exit 0
      fi

      apt-get install -y --no-install-recommends linux-generic-hwe-24.04
      echo "HWE kernel + tools installed; rebooting into >= 6.9"
    SHELL

    # ----------------------------------------------------------
    # Provisioner: network-tuning (maximize inter-VM throughput)
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "network-tuning", inline: <<-SHELL
      set -euxo pipefail

      cat > /etc/sysctl.d/99-network-perf.conf <<SYSCTL
# TCP buffer sizes (min, default, max) — 128 MB max
net.core.rmem_max=134217728
net.core.wmem_max=134217728
net.ipv4.tcp_rmem=4096 87380 134217728
net.ipv4.tcp_wmem=4096 65536 134217728

# Increase network device backlog
net.core.netdev_max_backlog=5000

# Enable TCP BBR congestion control
net.ipv4.tcp_congestion_control=bbr
net.core.default_qdisc=fq
SYSCTL
      sysctl --system

      # MTU 1500 on the transit interface. vmxnet3 rejects native XDP when
      # MTU > ~3000 ("MTU 9000 too large for XDP"), and the kfunc XDP datapath
      # (firewall/reject/ratelimit/LB) requires native attach — so jumbo
      # frames and native XDP are mutually exclusive here. 1500 keeps the
      # XDP datapath suites (46/47/48/51) working. Per-driver max-MTU matrix:
      #   https://docs.ebpf.io/linux/program-type/BPF_PROG_TYPE_XDP/#max-mtu
      # eth1 is the private_network interface
      if ip link show eth1 &>/dev/null; then
        ip link set eth1 mtu 1500
        # Persist via netplan
        NETPLAN_FILE=$(ls /etc/netplan/*.yaml 2>/dev/null | head -1)
        if [ -n "$NETPLAN_FILE" ] && ! grep -q 'mtu: 1500' "$NETPLAN_FILE" 2>/dev/null; then
          # Add MTU to eth1 config via a separate netplan file
          cat > /etc/netplan/99-mtu.yaml <<NETPLAN
network:
  version: 2
  ethernets:
    eth1:
      mtu: 1500
NETPLAN
          netplan apply 2>/dev/null || true
        fi
      fi
    SHELL

    # ----------------------------------------------------------
    # Provisioner: docker
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "docker", inline: <<-SHELL
      set -euxo pipefail
      export DEBIAN_FRONTEND=noninteractive

      if ! command -v docker &>/dev/null; then
        install -m 0755 -d /etc/apt/keyrings
        curl -fsSL https://download.docker.com/linux/ubuntu/gpg | \
          gpg --dearmor -o /etc/apt/keyrings/docker.gpg
        chmod a+r /etc/apt/keyrings/docker.gpg
        echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
          https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | \
          tee /etc/apt/sources.list.d/docker.list > /dev/null
        apt-get update
        apt-get install -y --no-install-recommends \
          docker-ce docker-ce-cli containerd.io docker-compose-plugin docker-buildx-plugin
        usermod -aG docker vagrant
      fi
    SHELL

    # ----------------------------------------------------------
    # Provisioner: kubernetes-tools (kubectl + minikube)
    # Installs the binaries the 10-kubernetes suite needs. minikube runs
    # with the docker driver (no nested VM), and conntrack — required by the
    # kube-proxy/kubelet on the node — is part of the base-packages set.
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "kubernetes-tools", inline: <<-SHELL
      set -euxo pipefail
      export DEBIAN_FRONTEND=noninteractive

      if ! command -v kubectl &>/dev/null; then
        KVER="$(curl -fsSL https://dl.k8s.io/release/stable.txt)"
        curl -fsSL -o /usr/local/bin/kubectl \
          "https://dl.k8s.io/release/${KVER}/bin/linux/$(dpkg --print-architecture)/kubectl"
        chmod +x /usr/local/bin/kubectl
      fi

      if ! command -v minikube &>/dev/null; then
        curl -fsSL -o /usr/local/bin/minikube \
          "https://storage.googleapis.com/minikube/releases/latest/minikube-linux-$(dpkg --print-architecture)"
        chmod +x /usr/local/bin/minikube
      fi

      # conntrack is a minikube hard dependency; ensure it is present.
      command -v conntrack &>/dev/null || apt-get install -y --no-install-recommends conntrack
    SHELL

    # ----------------------------------------------------------
    # Provisioner: rust (unprivileged)
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "rust", privileged: false, inline: <<-SHELL
      set -euxo pipefail

      if ! command -v rustc &>/dev/null; then
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
        source "$HOME/.cargo/env"
        rustup toolchain install nightly --component rust-src
        cargo +nightly install bpf-linker
      fi
    SHELL

    # ----------------------------------------------------------
    # Provisioner: ssh-access (enable password auth for attacker)
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "ssh-access", inline: <<-SHELL
      set -euxo pipefail

      # Set a known password for the vagrant user
      echo "vagrant:vagrant" | chpasswd

      # Enable password authentication in sshd
      sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
      sed -i 's/^#*ChallengeResponseAuthentication.*/ChallengeResponseAuthentication no/' /etc/ssh/sshd_config

      # Restart sshd to apply changes
      systemctl restart ssh || systemctl restart sshd
    SHELL

    # ----------------------------------------------------------
    # Provisioner: 3-VM transit routing (enable forwarding + MTU on eth2)
    # Only fires when VAGRANT_3VM is set; the agent acts as an IP router
    # between the client subnet (192.168.56.0/24) and the backend subnet
    # (192.168.57.0/24).
    # ----------------------------------------------------------
    if VAGRANT_3VM
      agent.vm.provision "shell", name: "transit-routing", inline: <<-SHELL
        set -euxo pipefail

        cat > /etc/sysctl.d/99-ebpfsentinel-forward.conf <<SYSCTL
net.ipv4.ip_forward=1
net.ipv6.conf.all.forwarding=1
net.ipv4.conf.all.rp_filter=0
net.ipv4.conf.default.rp_filter=0
SYSCTL
        sysctl --system

        # Jumbo frames on the backend-side NIC too
        if ip link show eth2 &>/dev/null; then
          ip link set eth2 mtu 1500
          cat > /etc/netplan/99-mtu-eth2.yaml <<NETPLAN
network:
  version: 2
  ethernets:
    eth2:
      mtu: 1500
NETPLAN
          netplan apply 2>/dev/null || true
        fi

        # Docker (installed for the container test strategy) sets the iptables
        # FORWARD policy to DROP and recreates the DOCKER-USER chain on every
        # daemon start, which silently kills the agent's transit forwarding
        # between the client (192.168.56.0/24) and backend (192.168.57.0/24)
        # subnets. Rules added once at provision time are lost on reboot, so
        # install a boot-time oneshot (ordered after docker) that re-inserts
        # idempotent ACCEPT rules into DOCKER-USER — the Docker-sanctioned hook
        # for user rules.
        cat > /usr/local/sbin/ebpf-transit-forward.sh <<'FWD'
#!/usr/bin/env bash
# Allow agent transit forwarding between the client and backend subnets
# despite Docker's default-DROP FORWARD chain. Idempotent.
set -u
CLIENT_NET="192.168.56.0/24"
BACKEND_NET="192.168.57.0/24"
# Wait briefly for the DOCKER-USER chain to exist (docker may still be starting).
for _ in $(seq 1 30); do
  iptables -L DOCKER-USER -n >/dev/null 2>&1 && break
  sleep 1
done
add_rule() {
  iptables -C DOCKER-USER "$@" 2>/dev/null || iptables -I DOCKER-USER "$@"
}
if iptables -L DOCKER-USER -n >/dev/null 2>&1; then
  add_rule -s "$CLIENT_NET"  -d "$BACKEND_NET" -j ACCEPT
  add_rule -s "$BACKEND_NET" -d "$CLIENT_NET"  -j ACCEPT
else
  # No Docker chain (docker not installed/running) — fall back to the main
  # FORWARD chain so plain kernel forwarding still works.
  iptables -C FORWARD -s "$CLIENT_NET"  -d "$BACKEND_NET" -j ACCEPT 2>/dev/null || iptables -I FORWARD -s "$CLIENT_NET"  -d "$BACKEND_NET" -j ACCEPT
  iptables -C FORWARD -s "$BACKEND_NET" -d "$CLIENT_NET"  -j ACCEPT 2>/dev/null || iptables -I FORWARD -s "$BACKEND_NET" -d "$CLIENT_NET"  -j ACCEPT
fi
FWD
        chmod +x /usr/local/sbin/ebpf-transit-forward.sh

        cat > /etc/systemd/system/ebpf-transit-forward.service <<UNIT
[Unit]
Description=Allow eBPFsentinel transit forwarding past Docker FORWARD DROP
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/ebpf-transit-forward.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
UNIT
        systemctl daemon-reload
        systemctl enable ebpf-transit-forward.service
        systemctl restart ebpf-transit-forward.service || true
      SHELL
    end

    # ----------------------------------------------------------
    # Provisioner: setup (external script, unprivileged)
    # ----------------------------------------------------------
    agent.vm.provision "shell", name: "setup", privileged: false, path: "provision/setup-agent.sh",
      env: {
        "PROVISION_MODE" => ENV.fetch('PROVISION_MODE', 'fast'),
        "VAGRANT_3VM"    => VAGRANT_3VM ? "1" : "0"
      }
  end

  # ============================================================
  # Attacker VM — runs attack and test tools against the agent
  # ============================================================
  config.vm.define "attacker" do |attacker|
    attacker.vm.box = "bento/ubuntu-24.04"
    attacker.vm.hostname = "ebpf-attacker"

    # Private network for inter-VM communication
    attacker.vm.network "private_network", ip: "192.168.56.20"

    # Sync project directory into VM (for test scripts)
    attacker.vm.synced_folder "../../../", "/home/vagrant/ebpfsentinel",
      type: "rsync",
      rsync__exclude: [".git/", "target/", "node_modules/", ".vagrant/"]

    # VirtualBox provider (default)
    attacker.vm.provider "virtualbox" do |vb|
      vb.memory = 2048
      vb.cpus = 2
      vb.name = "eBPFsentinel Attacker VM"
      vb.gui = false
    end

    # VMware Workstation provider (alternative)
    attacker.vm.provider "vmware_desktop" do |v|
      v.vmx["memsize"] = "2048"
      v.vmx["numvcpus"] = "2"
      v.vmx["displayname"] = "eBPFsentinel Attacker VM"
      v.gui = false
      v.linked_clone = false
    end

    # ----------------------------------------------------------
    # Provisioner: test-tools
    # ----------------------------------------------------------
    attacker.vm.provision "shell", name: "test-tools", inline: <<-SHELL
      set -euxo pipefail
      export DEBIAN_FRONTEND=noninteractive

      # The VMware NAT DNS resolver can lag a few seconds after boot, which
      # otherwise breaks the first github fetch below. Wait for it.
      for _ in $(seq 1 30); do
        getent hosts github.com >/dev/null 2>&1 && break
        sleep 2
      done

      apt-get update
      apt-get install -y --no-install-recommends \
        curl jq iperf3 hping3 ncat nmap bc openssl \
        sshpass stress-ng netcat-openbsd

      # Install bats from source (retry the clone — transient NAT DNS hiccups)
      if ! command -v bats &>/dev/null; then
        for attempt in 1 2 3; do
          rm -rf /tmp/bats-core
          git clone --depth 1 https://github.com/bats-core/bats-core.git /tmp/bats-core && break
          echo "bats clone attempt ${attempt} failed; retrying in 5s" >&2; sleep 5
        done
        (cd /tmp/bats-core && ./install.sh /usr/local)
        rm -rf /tmp/bats-core
      fi

      # Install grpcurl
      if ! command -v grpcurl &>/dev/null; then
        ARCH=$(dpkg --print-architecture)
        GRPCURL_VERSION="1.9.1"
        [ "$ARCH" = "amd64" ] && GRPCURL_ARCH="x86_64" || GRPCURL_ARCH="$ARCH"
        curl -sSL "https://github.com/fullstorydev/grpcurl/releases/download/v${GRPCURL_VERSION}/grpcurl_${GRPCURL_VERSION}_linux_${GRPCURL_ARCH}.tar.gz" | \
          tar -xz -C /usr/local/bin grpcurl
      fi
    SHELL

    # ----------------------------------------------------------
    # Provisioner: kernel-hwe
    #
    # bats runs on this VM, so its kernel gates the require_kernel checks
    # of every eBPF suite, and suite 61 starts a local agent here — and the
    # agent hard-refuses to start below 6.9. The bento/ubuntu-24.04 box
    # ships 6.8, so without this the kernel-gated suites all skip and the
    # PQ-handshake suite's setup_file fails. Mirror the agent VM: install
    # the HWE kernel (>= 6.9) and reboot into it.
    # ----------------------------------------------------------
    attacker.vm.provision "shell", name: "kernel-hwe", reboot: true, inline: <<-SHELL
      set -euxo pipefail
      export DEBIAN_FRONTEND=noninteractive

      apt-get update
      apt-get install -y --no-install-recommends linux-tools-generic-hwe-24.04

      running="$(uname -r | sed 's/-generic//')"
      if dpkg --compare-versions "$running" ge 6.9; then
        echo "kernel $running already >= 6.9, nothing to do"
        exit 0
      fi

      apt-get install -y --no-install-recommends linux-generic-hwe-24.04
      echo "HWE kernel + tools installed; rebooting into >= 6.9"
    SHELL

    # ----------------------------------------------------------
    # Provisioner: network-tuning (match agent VM settings)
    # ----------------------------------------------------------
    attacker.vm.provision "shell", name: "network-tuning", inline: <<-SHELL
      set -euxo pipefail

      cat > /etc/sysctl.d/99-network-perf.conf <<SYSCTL
net.core.rmem_max=134217728
net.core.wmem_max=134217728
net.ipv4.tcp_rmem=4096 87380 134217728
net.ipv4.tcp_wmem=4096 65536 134217728
net.core.netdev_max_backlog=5000
net.ipv4.tcp_congestion_control=bbr
net.core.default_qdisc=fq
SYSCTL
      sysctl --system

      # Jumbo frames on internal network
      if ip link show eth1 &>/dev/null; then
        ip link set eth1 mtu 1500
        cat > /etc/netplan/99-mtu.yaml <<NETPLAN
network:
  version: 2
  ethernets:
    eth1:
      mtu: 1500
NETPLAN
        netplan apply 2>/dev/null || true
      fi
    SHELL

    # ----------------------------------------------------------
    # Provisioner: 3-VM transit routing (route backend network via agent)
    # ----------------------------------------------------------
    if VAGRANT_3VM
      attacker.vm.provision "shell", name: "transit-routing", inline: <<-SHELL
        set -euxo pipefail

        # Static route: anything destined to the backend subnet goes via the
        # agent so attack traffic traverses the agent's eBPF datapath instead
        # of short-circuiting over the shared NAT segment. Persist via netplan
        # (networkd-dispatcher drop-ins only fire on routable transitions and
        # were unreliable — the route silently reverted to the NAT path).
        ip route replace 192.168.57.0/24 via 192.168.56.10 dev eth1 || true

        cat > /etc/netplan/99-3vm-route.yaml <<NETPLAN
network:
  version: 2
  ethernets:
    eth1:
      routes:
        - to: 192.168.57.0/24
          via: 192.168.56.10
NETPLAN
        chmod 600 /etc/netplan/99-3vm-route.yaml
        netplan apply 2>/dev/null || true
      SHELL
    end

    # ----------------------------------------------------------
    # Provisioner: setup (external script, unprivileged)
    # ----------------------------------------------------------
    attacker.vm.provision "shell", name: "setup", privileged: false, path: "provision/setup-attacker.sh"
  end

  # ============================================================
  # Backend VM — only created in 3-VM transit mode.
  # ============================================================
  if VAGRANT_3VM
    config.vm.define "backend" do |backend|
      backend.vm.box = "bento/ubuntu-24.04"
      backend.vm.hostname = "ebpf-backend"

      # Backend sits on the 192.168.57.0/24 segment. The VirtualBox host-only
      # adapter for this subnet only attaches to agent (eth2) and backend.
      backend.vm.network "private_network", ip: "192.168.57.30"

      backend.vm.synced_folder "../../../", "/home/vagrant/ebpfsentinel",
        type: "rsync",
        rsync__exclude: [".git/", "target/", "node_modules/", ".vagrant/"]

      backend.vm.provider "virtualbox" do |vb|
        vb.memory = 1024
        vb.cpus = 2
        vb.name = "eBPFsentinel Backend VM"
        vb.gui = false
      end

      backend.vm.provider "vmware_desktop" do |v|
        v.vmx["memsize"] = "1024"
        v.vmx["numvcpus"] = "2"
        v.vmx["displayname"] = "eBPFsentinel Backend VM"
        v.gui = false
        v.linked_clone = false
      end

      # Route client-side traffic back via the agent so transit policies
      # (NAT, conntrack, QoS, DSR L2) traverse the agent's eBPF datapath.
      backend.vm.provision "shell", name: "transit-routing", inline: <<-SHELL
        set -euxo pipefail

        # Return route: client-side traffic goes back via the agent so transit
        # policies (NAT, conntrack, QoS, DSR L2) traverse the agent's eBPF
        # datapath. Persist via netplan (see attacker note re: dispatcher).
        ip route replace 192.168.56.0/24 via 192.168.57.10 dev eth1 || true

        # MTU 1500 on the backend NIC (vmxnet3 native-XDP cap, path-wide match).
        if ip link show eth1 &>/dev/null; then
          ip link set eth1 mtu 1500
        fi

        cat > /etc/netplan/99-3vm-route.yaml <<NETPLAN
network:
  version: 2
  ethernets:
    eth1:
      mtu: 1500
      routes:
        - to: 192.168.56.0/24
          via: 192.168.57.10
NETPLAN
        chmod 600 /etc/netplan/99-3vm-route.yaml
        netplan apply 2>/dev/null || true
      SHELL

      backend.vm.provision "shell", name: "setup", privileged: false,
        path: "provision/setup-backend.sh"
    end
  end
end
